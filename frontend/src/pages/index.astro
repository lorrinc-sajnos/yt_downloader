---
// index.astro

// import "../scripts/client";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hello World</title>
    <style>
      /*#region Fonts*/
      @font-face {
        font-family: "HK Grotesk";
        src: url("/fonts/HKGrotesk/HKGrotesk-Light.otf") format("opentype");
        font-weight: 300;
        font-style: normal;
      }

      @font-face {
        font-family: "HK Grotesk";
        src: url("/fonts/HKGrotesk/HKGrotesk-LightItalic.otf")
          format("opentype");
        font-weight: 300;
        font-style: italic;
      }

      @font-face {
        font-family: "HK Grotesk";
        src: url("/fonts/HKGrotesk/HKGrotesk-Medium.otf") format("opentype");
        font-weight: 500;
        font-style: normal;
      }

      @font-face {
        font-family: "HK Grotesk";
        src: url("/fonts/HKGrotesk/HKGrotesk-MediumItalic.otf")
          format("opentype");
        font-weight: 500;
        font-style: italic;
      }

      @font-face {
        font-family: "HK Grotesk";
        src: url("/fonts/HKGrotesk/HKGrotesk-Bold.otf") format("opentype");
        font-weight: 700;
        font-style: normal;
      }

      @font-face {
        font-family: "HK Grotesk";
        src: url("/fonts/HKGrotesk/HKGrotesk-BoldItalic.otf") format("opentype");
        font-weight: 700;
        font-style: italic;
      }

      @font-face {
        font-family: "HK Grotesk";
        src: url("/fonts/HKGrotesk/HKGrotesk-ExtraBold.otf") format("opentype");
        font-weight: 800;
        font-style: normal;
      }

      @font-face {
        font-family: "Europa Grotesk";
        src: url("/fonts/EuropaGrotesk/europa-grotesk-medium.ttf")
          format("opentype");
        font-weight: 500; /* this file IS the 700 weight */
      }
      /*#endregion */

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      :root {
        --bg-color: #d3d2d2;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        background: var(--bg-color);
        font-family:
          "HK Grotesk",
          system-ui,
          -apple-system,
          sans-serif;
      }
      .page-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 2rem;
      }

      h1 {
        font-family: "Europa Grotesk", system-ui, sans-serif;
        font-size: 2.5rem;
        margin-bottom: 1.5rem;
        letter-spacing: -0.02em;
        font-weight: 500;
      }

      h2 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
        letter-spacing: -0.02em;
        font-family: "HK Grotesk";
        font-weight: 700;
      }

      button {
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        border-radius: 8px;
        border: none;
        background: #6d28d9;
        color: white;
        cursor: pointer;
        transition: background 0.2s ease;

        font-family:
          "HK Grotesk",
          system-ui,
          -apple-system,
          sans-serif;
        font-weight: 800;
      }

      button:hover {
        background: #5b21b6;
      }

      select {
        width: 6rem;
        padding: 0.75rem 1rem;
        border: 1px solid #ddd;
        border-radius: 16px; /* pill shape */
        font-size: 1rem;
        outline: none;
        transition:
          border-color 0.2s,
          box-shadow 0.2s;
        font-family: "HK Grotesk";
        font-weight: 500;
      }

      .fetch-card {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem;
      }

      .title-card {
        text-align: center;
        color: #353535;
        font-family: "Europa Grotesk";
      }

      .text-input {
        width: 30rem;
        padding: 0.75rem 1rem;
        border: 1px solid #ddd;
        border-radius: 16px; /* pill shape */
        font-size: 1rem;
        outline: none;
        transition:
          border-color 0.2s,
          box-shadow 0.2s;
        font-family: "HK Grotesk";
        font-weight: 300;
      }

      .thumbnail-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .thumbnail {
        display: block;
        width: 35vw;
        border-radius: 16px;
        object-fit: cover;
        margin: 0 auto;
      }

      /*Simple table*/
      .simple-table {
        width: 17vw;
        border-collapse: separate;
        border-spacing: 0;
        background-color: #ffffff;
        border-radius: 16px;
        overflow: hidden;
        font-family: "HK Grotesk";
        font-weight: 500;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.07);
      }

      .simple-table th,
      .simple-table td {
        padding: 1rem 1.1rem;
        text-align: left;
        border-bottom: 10px solid var(--bg-color);
      }

      .simple-table tbody tr:last-child td {
        border-bottom: none;
      }

      :global(.name) {
        font-weight: 700;
      }
      :global(.value) {
        font-weight: 300;
      }

      /*Loading Button*/
      .loading-btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 120px;
      }
      .loading-btn.is-loading {
        background: #461a8d;
      }

      .loading-btn .spinner {
        display: none;
        width: 1em;
        height: 1em;
        border: 2px solid currentColor;
        border-top-color: transparent;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }

      .loading-btn.is-loading .btn-text {
        visibility: hidden;
      }

      .loading-btn.is-loading .spinner {
        display: block;
        position: absolute;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      .compact-input {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
      }

      #res-select {
        width: 15rem;
      }

      #download-button {
        background: #22af91;
      }
      #download-button.loading-btn.is-loading {
        background: #14705c;
      }
      #download-button:hover {
        background: #1c8b73;
      }

      .download-spinner {
        width: 1em;
        height: 1em;
        border: 2px solid currentColor;
        border-top-color: transparent;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;

        display: block;
        position: absolute;
      }

      .metadata-card,
      .input-field-card {
        text-align: center;
      }

      #advanced-settigns-card {
        text-align: center;
        margin-top: 1.5rem;
        width: 100%;
        max-width: 26rem;
        background: #ffffff;
        border-radius: 16px;
        padding: 1.5rem 1.75rem 0.75rem;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.07);
      }

      #advanced-settigns-card h3 {
        margin: 0 0 1.1rem;
        font-family: "HK Grotesk";
        font-weight: 700;
        font-size: 1.2rem;
        color: #000000;
      }

      .setting-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
        padding: 0.7rem 0;
        border-bottom: 1px solid #efefef;
      }

      .setting-card:last-child {
        border-bottom: none;
      }

      .setting-card span {
        font-family: "HK Grotesk";
        font-weight: 500;
        font-size: 0.92rem;
        color: #4a4a4a;
        text-align: left;
      }

      #advanced-settigns-card span + input + span {
        color: #b7b7b7;
        font-weight: 300;
        font-size: 0.85rem;
      }

      /*#region Toggle Switch*/
      .settings-input {
        width: 4rem;
        padding: 0.45rem 0.6rem;
        border: 1.5px solid #e2e2e2;
        border-radius: 10px;
        font-size: 0.95rem;
        text-align: center;
        outline: none;
        transition:
          border-color 0.2s,
          box-shadow 0.2s;
        font-family: "HK Grotesk";
        font-weight: 500;
        color: #353535;
      }

      .settings-input:hover {
        border-color: #c9c9c9;
        background: #c9c9c9;
      }
      .settings-input:focus {
        border-color: #c9c9c9;
        background: #c9c9c9;
        box-shadow: 0 0 0 3px #e6e5e5;
      }

      .settings-input::placeholder {
        color: #c2c2c2;
        font-weight: 300;
      }

      .toggle-switch {
        display: inline-flex;
        background: #e2e2e2;
        border-radius: 999px;
        padding: 4px;
        gap: 4px;
      }

      .toggle-option {
        border: none;
        background: transparent;
        padding: 0.5rem 1.4rem;
        border-radius: 999px;
        font-family: "HK Grotesk";
        font-weight: 500;
        font-size: 0.9rem;
        color: #7a7a7a;
        cursor: pointer;
        transition:
          background 0.2s ease,
          color 0.2s ease,
          box-shadow 0.2s ease;
      }

      .toggle-option:hover:not(.is-active) {
        color: #4a4a4a;
      }

      .toggle-option.is-active {
        background: #ffffff;
        color: #353535;
        font-weight: 700;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
      }


      .codec {
        width: 9rem;
      }

      /*#endregion*/
    </style>
  </head>
  <body>
    <div class="page-container">
      <div class="title-card">
        <h1>Video Downloader</h1>
      </div>
      <div class="fetch-card">
        <input
          id="fetch-url-field"
          type="text"
          placeholder="https://www.youtube.com/example-video-url"
          class="text-input"
        />
        <button id="fetch-url-button" type="button" class="loading-btn">
          <span class="btn-text">Fetch video</span>
          <span class="spinner" aria-hidden="true"></span>
        </button>
      </div>

      <div class="thumbnail-card">
        <img id="thumbnail" alt="My image" class="thumbnail" />
        <h2 id="title-header"></h2>
      </div>

      <div id="metadata-card-id" class="metadata-card"></div>

      <div id="input-field-card" class="input-field-card">
        <table id="metadata-table" class="simple-table">
          <thead> </thead>
          <tbody> </tbody>
        </table>
      </div>

      <div class="compact-input" id="compact-input">
        <select id="output-format-select" name="output-format"> </select>
        <select id="res-select" name="res-format"> </select>
        <button id="download-button" type="button" class="loading-btn">
          <span class="btn-text">Download</span>
          <span class="spinner" aria-hidden="true"></span>
        </button>
      </div>

      <div class="toggle-switch" id="mode-toggle">
        <button type="button" class="toggle-option is-active" data-value="a"
          >A</button
        >
        <button type="button" class="toggle-option" data-value="b">B</button>
      </div>
      <div id="advanced-settigns-card">
        <h3>Advanced settings:</h3>
        <div class="setting-card">
          <span>FPS:</span>
          <input
            id="set-fps"
            type="text"
            placeholder="30"
            class="settings-input"
          />
        </div>
        <div class="setting-card">
          <span>Start:</span>
          <input
            id="set-start"
            type="text"
            placeholder="00:00"
            class="settings-input"
          />
        </div>
        <div class="setting-card">
          <span>Length:</span>
          <input
            id="set-length"
            type="text"
            placeholder="00:00"
            class="settings-input"
          />
        </div>

        <div class="setting-card">
          <span>Resolution:</span>
          <input
            id="set-res-x"
            type="text"
            placeholder=""
            class="settings-input"
          />

          <span>x</span>
          <input
            id="set-res-y"
            type="text"
            placeholder="480"
            class="settings-input"
          />
        </div>

        <div class="setting-card">
          <span>Video codec:</span>
          <select id="vc-select" class="codec"> </select>
        </div>
        <div class="setting-card">
          <span>Audio codec:</span>
          <select id="ac-select" class="codec"> </select>
        </div>
        <div class="setting-card">
          <span>Color effects:</span>
          <select id="cl-ch-select" class="codec"> </select>
        </div>
      </div>
      <!--End of page -->
    </div>
  </body>
</html>
<script type="module">
  import "../scripts/client";
</script>
